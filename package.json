{
  "name": "kogniffy-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "predev": "node scripts/ensure-next-font-manifest.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app src scripts next.config.ts eslint.config.mjs --max-warnings=0",
    "train:model": "node --import tsx scripts/train-model.ts",
    "train:dyslexia": "node --import tsx scripts/train-dyslexia-model.ts",
    "train:adhd": "node --import tsx scripts/train-adhd-model.ts",
    "generate:colorblind": "node --import tsx scripts/generate-colorblind-resources.ts",
    "train:colorblind": "node --import tsx scripts/train-colorblind-model.ts",
    "train:cognitiveperformance": "node --import tsx scripts/train-cognitiveperformance-model.ts",
    "train:reactiontime": "node --import tsx scripts/train-reactiontime-model.ts",
    "validate:models": "node --import tsx scripts/validate-model-artifacts.ts"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux",
        "win32"
      ],
      "cpu": [
        "current",
        "x64"
      ],
      "libc": [
        "current",
        "glibc"
      ]
    }
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "chart.js": "^4.4.7",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
